# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# ── Resend ───────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM="Mémoires Intactes <noreply@votredomaine.com>"

# Email interne de notification à chaque nouveau prospect (optionnel)
LEAD_NOTIFICATION_EMAIL=vous@exemple.com

# ── Relances automatiques (cron) ─────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # clé service_role (Settings → API)
CRON_SECRET=une_chaine_aleatoire_secrete
NEXT_PUBLIC_SITE_URL=https://votre-site.vercel.app
